# =====================================================
# 합격공간 Bridge 앱 환경설정
# 이 파일을 .env 로 복사한 뒤 값 채우기. 실제 .env 는 git에 올리지 말 것.
# =====================================================

# Bridge WebSocket 서버 포트 (브라우저 src/lib/deviceAgent.ts 와 동일)
WS_PORT=7421

# ----- NICE VAN 결제 -----
# NICE VAN 미들웨어 (NICEPAY POS Connector) 가 PC에서 듣고 있는 TCP 주소
NICE_HOST=127.0.0.1
NICE_PORT=9188

# 가맹점(결제 ID). 메인/서브 둘 다 운용 시 둘 다 입력. 기본은 메인.
NICE_MERCHANT_MAIN=3285619001
NICE_MERCHANT_SUB=3285620001

# 결제 인코딩 (NICE 일부 명세는 EUC-KR / CP949 사용)
NICE_ENCODING=cp949

# 면세 사업자 여부 (Y/N)
NICE_TAX_FREE=Y

# ----- Suprema BioStar 2 -----
# BioStar 2 서버 주소 (HTTPS 권장, 자체 인증서면 무시 옵션 켜기)
BIOSTAR_BASE_URL=https://127.0.0.1
BIOSTAR_USERNAME=admin
BIOSTAR_PASSWORD=
BIOSTAR_INSECURE_TLS=true

# 입퇴실 이벤트 폴링 주기 (ms). 너무 짧으면 서버 부하.
BIOSTAR_POLL_MS=3000

# 디바이스 ID (BioLite N2) — BioStar 2 콘솔에서 디바이스 추가 후 확인
BIOSTAR_DEVICE_ID=
