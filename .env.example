# Firebase 설정 (실 프로젝트 생성 후 채우기)
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=

# 디바이스 에이전트: "mock" 이면 가짜 카드/지문 응답, 그 외 ws://localhost:7421 시도
VITE_DEVICE_AGENT=mock

# 뿌리오(PPURIO) 메시지 발송 — Vercel 환경변수에만 등록 (코드/git에는 직접 박지 말 것)
# 미설정 시 /api/notify/send 는 mock 응답
PPURIO_USERNAME=
PPURIO_API_KEY=
PPURIO_SENDER=
# 알림톡용 발신프로필 (PPURIO 카카오 비즈채널 등록 후 발급) — SMS만 쓰면 생략 가능
PPURIO_SENDER_PROFILE=

# PPURIO는 IP 화이트리스트 인증 → 고정 IP VM 프록시 경유
# (2027-consulting/vm-proxy 와 동일한 프록시 사용)
PPURIO_PROXY_URL=
PPURIO_PROXY_SECRET=

# 토스페이먼츠 — 카드 / 가상계좌 / 결제 승인
# 비워두거나 'dummy' 로 시작하면 mock 모드 (시연용 가짜 응답)
# 가맹점이 2개 분리되어 있다면 MAIN / SUB 키 각각 등록.
# 단일 키만 있다면 TOSS_SECRET_KEY 한 줄로 fallback.
TOSS_SECRET_KEY_MAIN=
TOSS_SECRET_KEY_SUB=
TOSS_SECRET_KEY=dummy_demo
TOSS_BASE_URL=https://api.tosspayments.com
TOSS_DEFAULT_BANK=20

# 토스 클라이언트 키 (브라우저 노출용 — SDK 결제창 로딩)
VITE_TOSS_CLIENT_KEY=

# 토스 webhook 검증용 보안 키 (개발자센터에서 발급)
TOSS_WEBHOOK_SECRET=

# === 토스플레이스 (Toss Place) — 매장 단말기 결제 ===
# 단말기에서 결제 발생 시 payment.payment.approved.v1 웹훅을 받아
# pendingOrder.invoices[].orderId 매칭으로 자동 paid 처리.
# 시크릿: 토스플레이스 개발자센터 > 내 앱 > Webhook 메뉴에서 발급.
# 비워두면 mock 모드 — 시그니처 검증을 건너뛰고 모든 요청을 받음 (개발/시연용).
TOSSPLACE_WEBHOOK_SECRET=
# 가맹점 등록 후 통보받는 merchantId. 페이로드 검증에 사용 (옵션).
TOSSPLACE_MERCHANT_ID_MAIN=
TOSSPLACE_MERCHANT_ID_SUB=

# === 페이스패스 (Toss FacePass) — 얼굴 인증 출입 ===
# 토스 Front 단말의 plugin webview 가 등록/식별 콜백을 우리 서버로 POST.
# 현재는 토스 Front Plugin SDK 의 정식 시그니처(HMAC) 공개 전이라 단순 공유 시크릿으로
# 검증한다. SDK 정식 공개 후 HMAC 으로 교체.
# 비워두면 검증 건너뜀 (mock/시연 모드).
FACEPASS_CALLBACK_SECRET=

# === Firebase Admin SDK (webhook 핸들러용) ===
# Vercel 환경에 서비스 어카운트 JSON 을 통째로 넣거나 (raw JSON 또는 base64), 둘 다 안 넣으면
# applicationDefault() 로 폴백 (GCP 환경에서만 작동).
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# === 미입실 자동 스캔 (Vercel Cron) ===
# vercel.json 의 crons 스케줄에 따라 /api/notify/scan-noshow 가 호출됨.
# 요청은 Authorization: Bearer <CRON_SECRET> 헤더를 포함 — 아래 시크릿과 일치해야 처리.
# 비워두면 인증 스킵 (개발/시연). 운영에선 반드시 설정.
# NOTE: Vercel Hobby 플랜은 크론이 하루 1회로 제한됨 — 10분 간격이 필요하면 Pro 플랜.
CRON_SECRET=
# 셀프 콜 base URL — 없으면 https://${VERCEL_URL} 자동. 커스텀 도메인 사용 시 명시.
NOTIFY_BASE_URL=
