# Firebase 설정 (실 프로젝트 생성 후 채우기)
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=

# 디바이스 에이전트: "mock" 이면 가짜 카드/지문 응답, 그 외 ws://localhost:7421 시도
VITE_DEVICE_AGENT=mock

# 뿌리오(PPURIO) 메시지 발송 — Vercel 환경변수에만 등록 (코드/git에는 직접 박지 말 것)
# 미설정 시 /api/notify/send 는 mock 응답
PPURIO_USERNAME=
PPURIO_API_KEY=
PPURIO_SENDER=
# 알림톡용 발신프로필 (PPURIO 카카오 비즈채널 등록 후 발급) — SMS만 쓰면 생략 가능
PPURIO_SENDER_PROFILE=

# PPURIO는 IP 화이트리스트 인증 → 고정 IP VM 프록시 경유
# (2027-consulting/vm-proxy 와 동일한 프록시 사용)
PPURIO_PROXY_URL=
PPURIO_PROXY_SECRET=
